# Capimax BRX backend — environment template. Copy to `.env` and fill in.
# SPEC §1: all secrets come from environment variables; .env is never committed.

# --- Core Django ---
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database: a directly-installed local PostgreSQL (no Docker required) ---
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# Default PostgreSQL installs listen on 5432; some (e.g. PostgreSQL 18 on Windows)
# use 5433 — set the port to match YOUR install (README explains how to check).
DATABASE_URL=postgres://capimax:capimax@localhost:5432/capimax

# --- CORS: the React/Vite frontend origin(s). The Vite dev server is configured
#     for port 8080 (vite.config.ts), so allow that origin. ---
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# CORS_ALLOW_ALL_ORIGINS=false

# --- Frontend base URL (used to build verification / reset links) ---
FRONTEND_URL=http://localhost:5173

# --- JWT lifetimes (optional overrides) ---
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=14

# --- Email (dev prints to console; set a real provider in prod) ---
DEFAULT_FROM_EMAIL=no-reply@capimax.local
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# --- OAuth provider keys (leave blank in Phase 1; scaffolding only) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_KEY_ID=
APPLE_OAUTH_PRIVATE_KEY=

# --- Blockchain / custodial wallets (Phase 3 Wave 1). TESTNET ONLY (BSC, chain 97) ---
# Authenticated-encryption key for custodial private keys AT REST. Must live in the
# environment, SEPARATE from the database — a DB dump alone must be useless. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WALLET_ENCRYPTION_KEY=
# KeyManager backend protecting key material. "fernet-db" today; swap to a KMS/Vault
# backend later WITHOUT changing callers (see apps/wallets/keys.py).
KEY_MANAGER_BACKEND=fernet-db
# Network label stored on generated wallets.
WALLET_NETWORK=bsc-testnet

# Free public BSC Testnet RPC + chain id. Get your own (Ankr/QuickNode/Infura) if
# the public node rate-limits you. NEVER point this at mainnet in this wave.
BSC_TESTNET_RPC_URL=https://bsc-testnet-rpc.publicnode.com
CHAIN_ID=97
# Platform deployer/signer private key (TESTNET). Generate with:
#   python -c "from eth_account import Account; a=Account.create(); print(a.key.hex(), a.address)"
# Then FUND its address from a BSC Testnet faucet (https://testnet.bnbchain.org/faucet-smart).
# Env only — never commit, never store in the DB.
DEPLOYER_PRIVATE_KEY=
# Set after deploying the factory (manage.py deploy_factory OR blockchain/scripts/deploy.js).
PROPERTY_TOKEN_FACTORY_ADDRESS=
# Optional: BscScan API key for verifying contracts on the explorer.
BSCSCAN_API_KEY=

# --- KYC / KYB (Sumsub). Leave blank to run with the dev simulator; the gate
#     stays enforced but no live provider call is made. ---
# Approve KYC automatically in dev WITHOUT calling Sumsub (NEVER true in prod).
KYC_AUTO_APPROVE=false
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_WEBHOOK_SECRET=
SUMSUB_LEVEL_NAME=basic-kyc-level
SUMSUB_KYB_LEVEL_NAME=basic-kyb-level
# Owner business-verification (KYB) level — a SEPARATE level from the LP's, so the
# shared webhook routes owner applicants to the owner domain (Phase 7 Wave A).
SUMSUB_OWNER_KYB_LEVEL_NAME=owner-kyb-level
# Developer business-verification (KYB) level — a SEPARATE level from the owner's and
# LP's, so the shared webhook routes developer applicants to the developer domain
# (Phase 8 Wave A).
SUMSUB_DEVELOPER_KYB_LEVEL_NAME=developer-kyb-level
SUMSUB_BASE_URL=https://api.sumsub.com

# --- Payments: Stripe (card). Blank = code-complete but inert (no live charge).
#     Minting is gated on the SIGNATURE-VERIFIED webhook, so the webhook secret
#     is required for any real payment to mint tokens. ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# --- Payments: NOW Payments (crypto). Blank = inert. Minting is gated on the
#     signature-verified IPN callback (IPN secret required for real settlement).
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1
NOWPAYMENTS_PRICE_CURRENCY=usd

# --- Secondary-market platform fees (server-side; percent of gross). Overridable
#     without a frontend change. Defaults: LP market 1.0%, peer market 0.5%. ---
LP_MARKET_FEE_PERCENT=1.0
SECONDARY_MARKET_FEE_PERCENT=0.5

# --- Production-only (config.settings.prod) ---
# SECURE_SSL_REDIRECT=true
# SECURE_HSTS_SECONDS=2592000
