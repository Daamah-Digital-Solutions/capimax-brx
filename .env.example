# Capimax BRX — FRONTEND environment template (Vite).
# Copy to `.env` and fill in. `.env` is never committed (see .gitignore).
# NOTE: every VITE_* value is embedded into the client bundle and is therefore
# PUBLIC by design. Never put a private/secret key in a VITE_* variable.

# --- Django backend API base URL (the DRF backend; see backend/.env.example) ---
# Include the /api suffix; no trailing slash.
VITE_API_BASE_URL="http://localhost:8000/api"

# --- Google Sign-In (GIS) web client id — PUBLIC (safe to embed) ---
# The same value as the backend's GOOGLE_OAUTH_CLIENT_ID. When unset, the
# "Sign in with Google" button simply doesn't render (email/password still work).
# Must also be set in Vercel for production (triggers a rebuild).
VITE_GOOGLE_OAUTH_CLIENT_ID=""
