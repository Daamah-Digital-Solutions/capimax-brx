# Capimax BRX — FRONTEND environment template (Vite).
# Copy to `.env` and fill in. `.env` is never committed (see .gitignore).
# NOTE: every VITE_* value is embedded into the client bundle and is therefore
# PUBLIC by design. Never put a private/secret key in a VITE_* variable.

# --- Django backend API base URL (the DRF backend; see backend/.env.example) ---
VITE_API_BASE_URL="http://localhost:8000/api"

# --- Legacy Supabase (still used by not-yet-migrated domain features) ---------
# These are the PUBLIC project id, anon/publishable key, and URL — safe to ship
# to the browser, but kept out of git so each environment supplies its own.
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-publishable-key"
VITE_SUPABASE_URL="https://your-supabase-project-id.supabase.co"
